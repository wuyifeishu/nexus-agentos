# ── AgentOS Environment Configuration ────────────────────────────────────────
# Copy to .env and customize for your deployment.

# ── Server ──────────────────────────────────────────────────────────────
AGENTOS_ENV=production              # development | staging | production
AGENTOS_PORT=8000
AGENTOS_LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
AGENTOS_MAX_WORKERS=4
AGENTOS_TIMEOUT=60

# ── LLM Providers ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...
GOOGLE_API_KEY=...
# AGENTOS_DEFAULT_MODEL=gpt-4o
# AGENTOS_DAILY_BUDGET_USD=10.0

# ── Database ────────────────────────────────────────────────────────────
DB_URL=postgresql+asyncpg://agentos:changeme@localhost:5432/agentos
REDIS_URL=redis://localhost:6379/0

# ── Security ────────────────────────────────────────────────────────────
AGENTOS_SECRET_KEY=change-me-to-a-random-64-char-string
AGENTOS_JWT_ALGORITHM=HS256
AGENTOS_JWT_EXPIRE_MINUTES=1440
AGENTOS_CORS_ORIGINS=*

# ── Monitoring ──────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin

# ── Docker ──────────────────────────────────────────────────────────────
DB_PASSWORD=changeme
COMPOSE_PROJECT_NAME=agentos
